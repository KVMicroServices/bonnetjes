generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?   // Optional for OAuth users
  image         String?   // Profile image from OAuth provider
  emailVerified DateTime? // Email verification timestamp for OAuth
  role          String    @default("user") // "user" or "admin"
  lastNotificationReadAt DateTime? // Notifications newer than this are unread
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  receipts      Receipt[]
  adminActions  AdminAction[]
  accounts      Account[]
  comments      Comment[]
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?    // Google returns this field
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Receipt {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // File info
  cloudStoragePath    String
  isPublic            Boolean   @default(false)
  originalFilename    String
  fileType            String    // "image" or "pdf"
  fileSize            Int
  
  // Archive
  isArchived          Boolean   @default(false)
  archivedAt          DateTime?
  
  // Extracted data from OCR (primary data source)
  extractedShopName   String?
  extractedDate       DateTime?
  extractedAmount     Float?
  ocrConfidence       Int?      // 0-100
  ocrReasoning        String?
  
  // Verification results
  receiptReadable     Boolean?
  verificationStatus  String    @default("pending") // pending, verified, rejected, flagged
  processingStatus    String    @default("queued")  // idle, queued, processing, completed, failed
  failureReason       String?   // enum-like: NOT_A_RECEIPT, IMAGE_UNCLEAR, INSUFFICIENT_INFO, DUPLICATE_RECEIPT, RECEIPT_TOO_OLD, SUSPECTED_FRAUD, UNREADABLE_TEXT, MISSING_KEY_FIELDS
  secondaryAnalysis   String?   // secondary AI check reasoning on failures
  
  // Fraud detection
  imageHash           String?   // perceptual hash for duplicate detection
  isDuplicate         Boolean   @default(false)
  duplicateOfId       String?   // ID of original receipt if duplicate
  manipulationScore   Int?      // 0-100, higher = more likely manipulated
  manipulationFlags   String?   // JSON array of manipulation indicators
  suspiciousPatterns  String?   // JSON array of suspicious pattern flags
  fraudRiskScore      Int?      // 0-100 overall fraud risk
  
  // Timestamps
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  queuedAt            DateTime?
  processedAt         DateTime?
  
  // Admin actions
  adminActions        AdminAction[]

  // Comments
  comments            Comment[]
}

model AdminAction {
  id            String    @id @default(cuid())
  adminId       String
  admin         User      @relation(fields: [adminId], references: [id])
  receiptId     String
  receipt       Receipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  action        String    // "approve", "reject", "flag", "download"
  notes         String?
  createdAt     DateTime  @default(now())
}

model ReceiptSyncState {
  id             String   @id @default(cuid())
  reviewId       String   @unique
  tenantId       Int
  locationId     String
  status         String   // "PROCESSED" | "NO_RECEIPT" | "FAILED"
  s3Key          String?
  s3Etag         String?
  attemptCount   Int      @default(0)
  processedAt    DateTime @default(now())
  errorMessage   String?
  receiptContent String?  @db.Text // JSON blob with extracted metadata
  receiptId      String?  // FK to Receipt model when a Receipt record is created
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([reviewId, status])
}

model ReceiptSyncWatermark {
  id        String   @id @default(cuid())
  tenantId  Int      @unique
  watermark DateTime
  updatedAt DateTime @updatedAt
}

model ReceiptSyncTick {
  id                  String    @id @default(cuid())
  tenantId            Int
  startedAt           DateTime
  completedAt         DateTime?
  locationsDiscovered Int       @default(0)
  reviewsDiscovered   Int       @default(0)
  receiptsProcessed   Int       @default(0)
  noReceiptCount      Int       @default(0)
  failedCount         Int       @default(0)
  errorMessage        String?
  createdAt           DateTime  @default(now())

  @@index([tenantId, completedAt])
}

model ReviewDisableAudit {
  id          String    @id @default(cuid())
  receiptId   String
  reviewId    String
  locationId  String
  tenantId    Int
  status      String    @default("pending") // pending, success, failed
  attempts    Int       @default(0)
  lastError   String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([receiptId])
  @@index([reviewId])
  @@index([status])
}

model ReceiptDispute {
  id            String   @id @default(cuid())
  reviewId      String
  tenantId      Int?
  locationId    String?
  receiptId     String
  status        String   // verified, rejected, requires_review
  failureReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([reviewId])
  @@index([receiptId])
  @@index([status])
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  category  String
  action    String
  actorId   String?
  metadata  String?  @db.Text
  createdAt DateTime @default(now())

  @@index([category, createdAt])
  @@index([actorId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // receipt_requires_review, receipt_processed, review_disabled, dispute_outcome, role_changed, comment_mention
  title     String
  body      String
  metadata  String?  @db.Text // JSON blob with action-specific context (receiptId, etc.)
  userId    String?  // Target user — null means global (visible to all)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
}

model NotificationPreference {
  id       String @id @default(cuid())
  userId   String
  type     String // notification type (matches Notification.type)
  channel  String @default("in_app") // none, in_app, email

  @@unique([userId, type])
  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  body      String   @db.Text
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  receiptId String
  receipt   Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  mentions  String?  @db.Text // JSON array of mentioned user IDs
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([receiptId, createdAt])
  @@index([authorId])
}
