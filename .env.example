# Database
DATABASE_URL='postgresql://user:password@host:port/dbname'

# Redis (BullMQ queue)
REDIS_URL=redis://localhost:6379
QUEUE_WORKER_CONCURRENCY=3
# Port for queue worker health check endpoint (default: 3001)
WORKER_HEALTH_PORT=3001

# Authentication
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (for Drive Import)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# AI / OCR Provider (OpenAI Compatible)
AI_API_KEY=your_ai_api_key
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL_NAME=gpt-5.4-nano
SECONDARY_AI_MODEL_NAME=gpt-5.4-mini
OCR_REASONING_MAX_TOKENS=150

# Storage (S3 Compatible - Cloudflare R2, Backblaze B2, etc.)
AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
AWS_REGION=auto
AWS_BUCKET_NAME=your_bucket_name
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
# Optional: folder prefix in bucket
AWS_FOLDER_PREFIX=uploads/

# Review Platforms (Kiyoh & KlantenVertellen) - INTERNAL, DO NOT SHARE
KIYOH_API_TOKEN=your_kiyoh_api_token
KV_API_TOKEN=your_kv_api_token

# Receipt Sync Service - KV Platform Integration
# KV platform API base URL (required for sync, e.g. https://www.klantenvertellen.nl/v1/publication)
KV_API_BASE_URL=https://www.klantenvertellen.nl/v1/publication
# Comma-separated tenantId:token pairs (required for sync)
KV_PUBLICATION_API_TOKENS=12345:your_token_here

# Receipt Sync Service - KV S3 Bucket (receipt file storage)
# S3 bucket name for KV receipts (required for S3 receipt fetching)
KV_RECEIPT_S3_BUCKET_NAME=your_kv_receipt_bucket
# AWS region for KV S3 bucket (default: eu-central-1)
KV_RECEIPT_AWS_REGION=eu-central-1
# AWS access key for KV bucket
KV_RECEIPT_AWS_ACCESS_KEY_ID=your_kv_aws_access_key
# AWS secret key for KV bucket
KV_RECEIPT_AWS_SECRET_ACCESS_KEY=your_kv_aws_secret_key

# Receipt Sync Service - Polling and Performance
# Seconds between sync ticks (default: 300)
POLL_INTERVAL_SECONDS=300
# Seconds subtracted from watermark for clock skew safety (default: 60)
WATERMARK_SAFETY_SECONDS=60
# Items per page for KV API pagination (default: 200)
PAGE_SIZE=200
# Max parallel location workers (default: 4)
WORKER_CONCURRENCY=4
# Min seconds between KV API requests (default: 1)
API_RATE_LIMIT=1

# Receipt Sync Service - Behavior
# Auto-verify synced receipts (default: false)
RECEIPT_AUTO_VERIFY_ENABLED=false
RECEIPT_AUTO_DISABLE_ENABLED=false
# Max retries before dead letter (default: 5)
MAX_RETRY_ATTEMPTS=5


KIYOH_ADMIN_TOTP="totp"
KIYOH_ADMIN_USERNAME="username"
KIYOH_ADMIN_PASSWORD="password"

# Review Platform URLs (defaults to KlantenVertellen)
# Auth base URL for login + OTP verification
KIYOH_AUTH_BASE_URL=https://www.klantenvertellen.nl/v1/authentication
# Review API base URL for enable/disable operations
KIYOH_REVIEW_API_BASE_URL=https://www.klantenvertellen.nl/v1/review
# Context endpoint URL — exchanges login hash for the real bearer token
KIYOH_CONTEXT_URL=https://www.klantenvertellen.nl/v1/common/context
# Review list API URL for fetching reviewer details (email resolution)
KIYOH_REVIEW_LIST_URL=https://www.klantenvertellen.nl/v1/review
# Tenant ID for the platform
KIYOH_ADMIN_TENANT=99

#Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM="ReviewReceipts <your-email@gmail.com>"

# Application URL (used for email links such as dispute page)
APP_URL=http://localhost:3000